{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePictureUrl": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "premium"] },
        "walletAddress": { "type": "string" },
        "selectedWalletType": { "type": "string" },
        "points": { "type": "number" },
        "freeMarketingContentUsed": { "type": "number" },
        "warnings": { "type": "number" },
        "isBanned": { "type": "boolean" },
        "isNewUser": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "referralCodeUsed": { "type": "boolean" },
        "uniqueLoginCode": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["email", "username"]
    },
    "Project": {
      "title": "Project",
      "description": "A generated software project (metadata)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "creationMode": { "type": "string" },
        "iconUrl": { "type": "string" },
        "sections": { "type": "array" },
        "timestamp": { "type": "number" },
        "updatedAt": { "type": "number" },
        "ownerUid": { "type": "string" },
        "isShared": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "isBoosted": { "type": "boolean" },
        "boostEndDate": { "type": "number" },
        "fileCount": { "type": "number" },
        "messageCount": { "type": "number" }
      },
      "required": ["name", "ownerUid", "timestamp"]
    },
    "ProjectFile": {
      "title": "ProjectFile",
      "description": "A file belonging to a project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "language": { "type": "string" },
        "content": { "type": "string" },
        "storageUrl": { "type": "string" },
        "projectId": { "type": "string" },
        "updatedAt": { "type": "number" }
      }
    },
    "ProjectMessage": {
      "title": "ProjectMessage",
      "description": "A message in the builder chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "timestamp": { "type": "number" },
        "projectId": { "type": "string" },
        "attachments": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Software projects (metadata)"
    },
    "/projects/{projectId}/files/{fileId}": {
      "schema": "ProjectFile",
      "description": "Individual project files"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "ProjectMessage",
      "description": "Builder chat messages"
    }
  }
}
