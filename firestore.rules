rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprint
    function isValidUser(data) {
      return (data.get('email', '') is string) &&
             (data.get('username', '') is string) &&
             (data.get('points', 0) is number) &&
             (data.get('plan', 'free') in ['free', 'pro', 'premium']);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerUid', 'timestamp']) &&
             data.name is string && data.name.size() <= 200 &&
             data.ownerUid == request.auth.uid &&
             data.timestamp is number &&
             (data.get('description', '') is string) &&
             (data.get('fileCount', 0) is number) &&
             (data.get('messageCount', 0) is number);
    }

    function isValidFile(data) {
      return data.keys().hasAll(['name', 'projectId', 'updatedAt']) &&
             data.name is string && data.name.size() <= 256 &&
             data.projectId is string &&
             data.updatedAt is number &&
             (data.get('content', '') is string) &&
             (data.get('storageUrl', '') is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['sender', 'projectId', 'timestamp']) &&
             data.sender is string &&
             data.projectId is string &&
             data.timestamp is number &&
             (data.get('text', '') is string);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
            'uid', 'name', 'username', 'profilePictureUrl', 'walletAddress', 'selectedWalletType',
            'referralCode', 'referralCodeUsed', 'points', 'freeMarketingContentUsed',
            'warnings', 'isBanned', 'isNewUser', 'uniqueLoginCode', 'plan', 'timestamp', 'email'
        ])
      );
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid;
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerUid) || (existing().get('isShared', false) == true) || (existing().get('publicShareId', '') != '');
      allow list: if (isSignedIn() && resource.data.ownerUid == request.auth.uid) || (resource.data.publicShareId != '');

      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if isOwner(existing().ownerUid) && isValidProject(incoming()) && (
        incoming().ownerUid == existing().ownerUid
      );
      allow delete: if isOwner(existing().ownerUid);

      match /files/{fileId} {
        allow read: if isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid) || (get(/databases/$(database)/documents/projects/$(projectId)).data.get('isShared', false) == true) || (get(/databases/$(database)/documents/projects/$(projectId)).data.get('publicShareId', '') != '');
        allow write: if isProjectOwner(projectId) && isValidFile(incoming());
      }

      match /messages/{messageId} {
        allow read: if isProjectOwner(projectId);
        allow write: if isProjectOwner(projectId) && isValidMessage(incoming());
      }
    }
  }
}
