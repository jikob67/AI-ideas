rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Test Connection ---
    match /test/connection {
      allow get: if true;
    }

    // Pillar 2: Validation Blueprint
    function isValidUser(data) {
      return (data.get('email', '') is string) &&
             (data.get('username', '') is string) &&
             (data.get('points', 0) is number) &&
             (data.get('plan', 'free') in ['free', 'pro', 'premium']);
    }

    function isValidProject(data) {
      let isCreating = request.method == 'create';
      return (!isCreating || (data.keys().hasAll(['name', 'ownerUid', 'timestamp']))) &&
             (!data.keys().hasAny(['name']) || data.name is string) &&
             (!data.keys().hasAny(['ownerUid']) || data.ownerUid == request.auth.uid) &&
             (!data.keys().hasAny(['timestamp']) || data.timestamp is number) &&
             (!data.keys().hasAny(['description']) || data.description is string) &&
             (!data.keys().hasAny(['isPublished']) || data.isPublished is bool) &&
             (!data.keys().hasAny(['apkUrl']) || data.apkUrl is string) &&
             (!data.keys().hasAny(['ipaUrl']) || data.ipaUrl is string) &&
             (!data.keys().hasAny(['liveUrl']) || data.liveUrl is string);
    }

    function isValidFile(data) {
      return data.keys().hasAll(['name', 'projectId', 'updatedAt']) &&
             data.name is string && data.name.size() <= 256 &&
             data.projectId is string &&
             data.updatedAt is number &&
             (data.get('content', '') is string) &&
             (data.get('storageUrl', '') is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['sender', 'projectId', 'timestamp']) &&
             data.sender is string &&
             data.projectId is string &&
             data.timestamp is number &&
             (data.get('text', '') is string);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: General Info Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'username', 'profilePictureUrl', 'walletAddress', 'selectedWalletType', 'uniqueLoginCode', 'timestamp', 'email'])) ||
        // Action: New User Onboarding Completion
        (incoming().diff(existing()).affectedKeys().hasOnly(['isNewUser']) && existing().isNewUser == true) ||
        // Action: Point Awarding (Harden this: only increments, max 100 at a time)
        (incoming().diff(existing()).affectedKeys().hasOnly(['points']) && incoming().points > existing().points && (incoming().points - existing().points) <= 100)
      ) && (
        // Immutable & System Fields Safety
        !incoming().diff(existing()).affectedKeys().hasAny(['plan', 'isBanned', 'warnings', 'referralCodeUsed', 'freeMarketingContentUsed', 'referralCode'])
      );
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid;
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerUid) || (existing().get('isShared', false) == true) || (existing().get('publicShareId', '') != '') || (existing().get('isPublished', false) == true);
      allow list: if (isSignedIn() && resource.data.ownerUid == request.auth.uid) || (resource.data.publicShareId != '') || (resource.data.get('isPublished', false) == true);

      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if (isOwner(existing().ownerUid) && isValidProject(incoming())) || (
        existing().get('isPublished', false) == true &&
        incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'views']) &&
        (incoming().get('likes', 0) == existing().get('likes', 0) + 1 || incoming().get('likes', 0) == existing().get('likes', 0) - 1 || incoming().get('likes', 0) == existing().get('likes', 0)) &&
        (incoming().get('views', 0) == existing().get('views', 0) + 1 || incoming().get('views', 0) == existing().get('views', 0))
      );
      allow delete: if isOwner(existing().ownerUid);

      match /files/{fileId} {
        allow read: if isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid) || 
                     (get(/databases/$(database)/documents/projects/$(projectId)).data.get('isShared', false) == true) || 
                     (get(/databases/$(database)/documents/projects/$(projectId)).data.get('publicShareId', '') != '') ||
                     (get(/databases/$(database)/documents/projects/$(projectId)).data.get('isPublished', false) == true);
        allow write: if isProjectOwner(projectId) && isValidFile(incoming());
      }

      match /messages/{messageId} {
        allow read: if isProjectOwner(projectId);
        allow write: if isProjectOwner(projectId) && isValidMessage(incoming());
      }

      match /snapshots/{snapshotId} {
        allow read, write: if isProjectOwner(projectId);
      }
    }
  }
}
