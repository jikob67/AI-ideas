rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read for blobs so share links work
    // Restrict write/delete to authenticated owners
    match /blobs/{blobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Legacy mapping (backward compatibility)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
